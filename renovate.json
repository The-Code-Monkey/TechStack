{
  "extends": [
    ":dependencyDashboard",
    ":semanticPrefixFixDepsChoreOthers",
    ":ignoreModulesAndTests",
    "group:monorepos",
    "group:recommended",
    "workarounds:all"
  ],
  "dependencyDashboard": true,
  "rangeStrategy": "pin",
  "automergeStrategy": "squash",
  "automerge": true,
  "prConcurrentLimit": 3,
  "labels": ["dependencies"],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "enabled": true
  },
  "packageRules": [
    {
      "enabled": false,
      "matchPackageNames": [
        "/node/"
      ]
    }
  ],
  "updateInternalDeps": true
}
