{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "build/**"
      ]
    },
    "lint": {},
    "test": {
      "dependsOn": [
        "build"
      ]
    },
    "size": {
      "dependsOn": [
        "build"
      ]
    },
    "build-storybook": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "storybook-static/**",
        "build/**"
      ]
    }
  }
}