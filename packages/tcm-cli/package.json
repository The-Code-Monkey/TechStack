  "type": "module",
  "typings": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "node dist/index.js lint ./",
    "start": "tsc -p tsconfig.json --watch",
    "deduplicate": "npm dedupe",
    "deduplicate:check": "npm dedupe -c",
    "doctoc": "doctoc README.md"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "src/conf"
  ],
